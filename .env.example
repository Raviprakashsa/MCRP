# ======================================================================
# MCRP — Environment variables
# Copy to `.env.local` (git-ignored) and fill in. NEVER put real secrets in
# this example file. Production values are set in the Vercel dashboard.
# Legend:  [REQUIRED] must be set  ·  [OPTIONAL] feature-gated
#          [DEV] local value shown  ·  [PROD] production value shown
# ======================================================================

# --- Supabase: public (browser-safe) ----------------------------------
# [REQUIRED] Project URL. Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# [REQUIRED] Publishable / anon key (safe for the browser; access is governed
# by Row Level Security). Format: sb_publishable_... (or the legacy anon JWT).
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-PUBLISHABLE-KEY

# [REQUIRED] Public site URL — used to build auth email + OAuth redirect links.
# [DEV]  http://localhost:3000
# [PROD] https://careers.magnuscopo.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase: server-only secret (NEVER exposed to the browser) -------
# [REQUIRED] Service-role / secret key. Supabase → Project Settings → API →
# "service_role" (format: sb_secret_...). Full DB access, bypasses RLS.
# Used by duplicate-detection and the super-admin bootstrap. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SECRET-KEY

# --- Super-admin bootstrap --------------------------------------------
# [OPTIONAL] Email auto-promoted to super_admin on first login. Leave blank to
# disable (manual SQL promotion remains available).
SUPER_ADMIN_EMAIL=

# ======================================================================
# Notes
# - Google login needs NO env var here: the app auto-detects whether Google is
#   enabled in Supabase and shows/hides the button accordingly. Configure
#   Google in the Google Cloud + Supabase dashboards (see docs/deployment).
# - The database password and direct connection string are NOT app env vars;
#   they are only used by the Supabase CLI / direct DB tools, never by the app.
# ======================================================================
